# ==============================================================================
# AI Phone Interpreter - Environment Configuration Template
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit a real .env file - it will contain live API keys and secrets.
# ==============================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=interpreter
POSTGRES_PASSWORD=change_me_in_dev
POSTGRES_DB=interpreter_db
DATABASE_URL=postgresql://interpreter:change_me_in_dev@postgres:5432/interpreter_db

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Auth (Phase 4) ----------
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# India phone-number OTP auth provider (e.g. MSG91, Twilio Verify) - filled in Phase 4
OTP_PROVIDER_API_KEY=

# ---------- Speech-to-Text provider (Phase 8) ----------
# We start with a cloud STT provider behind an STTProvider interface, so this
# key is provider-specific - fill in whichever we choose in Phase 8.
STT_PROVIDER=google        # google | azure | openai
STT_PROVIDER_API_KEY=
STT_PROVIDER_REGION=

# ---------- Translation provider (Phase 12) ----------
# Meaning-preserving translation is LLM-driven, not a literal-translation API.
TRANSLATION_PROVIDER=anthropic   # anthropic | openai
TRANSLATION_PROVIDER_API_KEY=

# ---------- Text-to-Speech provider (Phase 13) ----------
TTS_PROVIDER=google         # google | azure | elevenlabs
TTS_PROVIDER_API_KEY=

# ---------- WebRTC / TURN server (Phase 5) ----------
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# ---------- General ----------
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
